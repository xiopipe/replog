# pnpm config for Expo / React Native.
# Metro and the native build cannot follow pnpm's symlinked store, so use a
# flat (hoisted) node_modules just like npm/yarn-classic.
node-linker=hoisted
# Auto-install peer deps so RN/Expo peer ranges resolve without manual pins.
auto-install-peers=true
# Tolerant peer resolution (replaces npm's legacy-peer-deps).
strict-peer-dependencies=false
